# Expo는 EXPO_PUBLIC_ 접두사가 붙은 변수만 앱에서 읽을 수 있습니다.
# 값을 바꾼 뒤에는 Metro를 재시작하세요 (Ctrl+C → npm start).

# --- 실행 환경별로 하나만 사용하세요 ---

# iOS 시뮬레이터 / 웹 (Mac에서 백엔드 실행 시)
EXPO_PUBLIC_API_URL=http://localhost:8080

# Android 에뮬레이터 (호스트 PC의 localhost = 10.0.2.2)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080

# 실제 iPhone / Android 실기기 (Mac IP로 교체, 예: ifconfig en0)
# Metro QR에 보이는 IP와 동일하게 맞추세요. localhost는 실기기에서 동작하지 않습니다.
# EXPO_PUBLIC_API_URL=http://192.168.0.10:8080

# WebSocket(STOMP)은 기본적으로 API URL에서 ws:// 주소로 자동 변환됩니다.
# EXPO_PUBLIC_WS_URL=ws://192.168.0.10:8080/api/ws-stomp
